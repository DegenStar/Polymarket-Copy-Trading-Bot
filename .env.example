# ═══════════════════════════════════════════════════════════════════════════
# TRADING MODE — pick which bot `npm start` launches
# 交易模式 — 选择 `npm start` 启动哪个机器人
# ═══════════════════════════════════════════════════════════════════════════
#   arb  → 9-rule BTC Up/Down auto-trading strategy (default)
#   arb  → 9 条规则的 BTC 涨跌自动交易策略（默认）
#   copy → BUY-only copy trader that mirrors COPY_TARGETS below
#   copy → 仅做买的跟单机器人，镜像下方 COPY_TARGETS 中的地址
TRADING_MODE=arb

# ── Wallet ──────────────────────────────────────────────────────────────────
# ── 钱包 ──────────────────────────────────────────────────────────────────
# Your Polygon EOA private key (controls the Polymarket proxy wallet).
# 你的 Polygon EOA 私钥（用于控制 Polymarket 代理钱包）。
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE34534543

# The Polymarket proxy wallet address associated with your account.
# 与你账户关联的 Polymarket 代理钱包地址。
# Retrieve from https://polymarket.com after connecting your wallet.
# 连接钱包后从 https://polymarket.com 获取。
PROXY_WALLET=0xYOUR_PROXY_WALLET_HERE345345

# ── Polymarket CLOB API credentials ─────────────────────────────────────────
# ── Polymarket CLOB API 凭证 ────────────────────────────────────────────────
# Derived once via auth flow (run `node src/auth.js` to generate and store these).
# 通过认证流程一次性派生（运行 `node src/auth.js` 生成并保存）。
# Leave blank on first run; the bot will derive them automatically.
# 首次运行可留空；机器人会自动派生。
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=

# ── Polygon RPC ──────────────────────────────────────────────────────────────
# ── Polygon RPC ─────────────────────────────────────────────────────────────
# Use a private endpoint (Alchemy / Infura / QuickNode) for reliability.
# 建议使用私有 RPC 端点（Alchemy / Infura / QuickNode）以提高稳定性。
POLYGON_RPC=https://polygon-rpc.com

# ── Risk parameters ──────────────────────────────────────────────────────────
# ── 风险参数 ────────────────────────────────────────────────────────────────
# Maximum USDC to spend (buy-side) in a single 5-min market.
# 单个 5 分钟市场内买入侧最多花费的 USDC。
MAX_SPEND_PER_MARKET=400

# Stop buying the over-held side when |Up_shares - Down_shares| exceeds this USDC value.
# 当 |Up 份额 - Down 份额| 超过此 USDC 值时，停止买入持仓过多的一侧。
MAX_INVENTORY_IMBALANCE_USDC=200

# Minimum arb edge required before firing a taker buy (Rule 3).
# 触发 taker 买入（规则 3）前所需的最低套利边际。
# 0.02 = at least 2c net per pair after gas.
# 0.02 = 扣除 gas 后每对至少净赚 2 美分。
TARGET_EDGE=0.02

# Minimum matched pairs (in USDC equivalent) before calling mergePositions (Rule 4).
# 调用 mergePositions（规则 4）前所需的最小配对数量（USDC 等值）。
# Keep >= 10 to amortise gas.
# 建议 >= 10，以摊薄 gas 成本。
MERGE_THRESHOLD_USDC=15

# Maximum size per individual taker fill, in USDC.
# 单笔 taker 成交的最大规模（USDC）。
MAX_TAKER_FILL_USDC=100

# Combined-ask circuit-breaker: pull orders if best_ask_up + best_ask_down > this.
# 组合卖价熔断：若 best_ask_up + best_ask_down 超过此值则撤单。
COMBINED_ASK_STOP=1.02

# Max cumulative realized loss per hour before halting the bot.
# 每小时累计已实现亏损上限，超过则停止机器人。
MAX_LOSS_PER_HOUR_USDC=300

# ── Ladder parameters ────────────────────────────────────────────────────────
# ── 阶梯挂单参数 ────────────────────────────────────────────────────────────
# Comma-separated list of round-cent price levels for both Up and Down.
# Up 与 Down 两侧共用的整美分价格档位列表（逗号分隔）。
LADDER_LEVELS=0.02,0.05,0.10,0.15,0.20,0.25,0.30,0.35,0.40,0.45,0.48,0.50,0.52,0.55,0.60,0.65,0.70,0.75,0.80,0.85,0.90,0.95,0.98

# USDC to allocate per ladder level per side.
# 每个档位、每一侧分配的 USDC 数量。
LADDER_SIZE_PER_LEVEL_USDC=20

# ── Logging ──────────────────────────────────────────────────────────────────
# ── 日志 ────────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ═══════════════════════════════════════════════════════════════════════════
# BUY-ONLY COPY TRADER (`npm run copy`) — optional; ignored by the arb bot
# 仅做买的跟单机器人（`npm run copy`）— 可选；套利机器人会忽略这些项
# ═══════════════════════════════════════════════════════════════════════════

# Comma-separated Polymarket proxy-wallet addresses to mirror.
# 要跟单的 Polymarket 代理钱包地址（逗号分隔）。
# Example: the wallet you've been reverse-engineering.
# 示例：你正在逆向分析的钱包地址。
COPY_TARGETS=0xcfb103c37c0234f524c632d964ed31f117b5f694

# Sizing mode: FIXED | MIRROR | RATIO
# 下单规模模式：FIXED | MIRROR | RATIO
#   FIXED  — always spend exactly COPY_FIXED_USDC per copied trade
#   FIXED  — 每笔跟单固定花费 COPY_FIXED_USDC
#   MIRROR — spend the same USDC the target spent
#   MIRROR — 与目标花费相同的 USDC
#   RATIO  — spend COPY_RATIO × target's USDC
#   RATIO  — 花费 COPY_RATIO × 目标 USDC
COPY_SIZE_MODE=FIXED
COPY_FIXED_USDC=10
COPY_RATIO=0.10

# Execution caps (USDC)
# 执行上限（USDC）
COPY_MAX_USDC_PER_TRADE=50
COPY_MAX_USDC_PER_MARKET=200
COPY_MAX_USDC_PER_HOUR=500
COPY_MAX_USDC_TOTAL=2000

# Slippage / price guardrails
# 滑点 / 价格护栏
COPY_MAX_SLIPPAGE=0.03
COPY_MAX_PRICE=0.97
COPY_MIN_PRICE=0.02

# Drop trades older than this (ms) at detection time — don't chase stale signal.
# 检测时丢弃超过此时长（毫秒）的交易 — 不追陈旧信号。
COPY_STALE_MS=8000

# Poll interval per target (ms). 250ms = ~4 req/s per wallet.
# 每个目标的轮询间隔（毫秒）。250ms ≈ 每个钱包约 4 次请求/秒。
COPY_POLL_MS=250

# Optional allow/block lists (comma-separated 0x-prefixed conditionIds).
# 可选的允许/屏蔽列表（逗号分隔、0x 开头的 conditionId）。
# Leave COPY_ALLOWED_CONDITIONS empty to copy any market the target trades.
# COPY_ALLOWED_CONDITIONS 留空则跟单目标交易的任意市场。
COPY_ALLOWED_CONDITIONS=
COPY_BLOCKED_CONDITIONS=

# Set true to log everything without actually sending orders.
# 设为 true 则只记录日志、不实际下单。
COPY_DRY_RUN=false
